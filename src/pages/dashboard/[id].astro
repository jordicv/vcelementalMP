    .log-entry:last-child {
      border-bottom: none;
    }
    .log-timestamp {
      color: var(--muted2);
      font-weight: 700;
      margin-right: 4px;
    }
    
    .btn-export {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 12px;
      font-weight: 600;
