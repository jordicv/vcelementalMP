  <script>
    // 1. Agregar a Interesantes (Toast)
    const interestedBtn = document.getElementById('btn-interested');
    const toast = document.getElementById('success-toast');

    if (interestedBtn) {
      interestedBtn.addEventListener('click', () => {
        if (toast) {
          toast.classList.add('show');
          setTimeout(() => {
            toast.classList.remove('show');
          }, 3000);
        }
      });
    }

    // 2. Controladores de Pestañas del Explorer
    const navButtons = document.querySelectorAll('.nav-btn');
    const panels = document.querySelectorAll('.tab-panel');

    navButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Desactivar todos los botones
        navButtons.forEach(b => b.classList.remove('active'));
        // Ocultar todos los paneles
        panels.forEach(p => p.classList.remove('active'));

        // Activar botón clickeado
        btn.classList.add('active');
        
        // Mostrar panel correspondiente
        const targetId = btn.getAttribute('data-target');
        if (targetId) {
          const targetPanel = document.getElementById(targetId);
          if (targetPanel) {
            targetPanel.classList.add('active');
          }
        }
      });
    });

    // 3. Script para la Guía Paso a Paso (Checklist, Asignaciones, Bitácora y Confeti)
    const panelPasoAPaso = document.getElementById('panel-pasoapaso');
    const tenderCode = panelPasoAPaso ? panelPasoAPaso.getAttribute('data-tender-code') : '';
    const progressText = document.getElementById('pasoapaso-progress-text');
    const progressBar = document.getElementById('pasoapaso-progress-bar');
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    const logList = document.getElementById('activity-log-list');
    const exportBtn = document.getElementById('btn-export-checklist');

    // Confetti Animation Implementation
    class ConfettiEffect {
      private canvas: HTMLCanvasElement;
      private ctx: CanvasRenderingContext2D | null;
      private particles: Array<any> = [];
      private active: boolean = false;
      private colors: string[] = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'];

      constructor(canvasElement: HTMLCanvasElement) {
        this.canvas = canvasElement;
        this.ctx = canvasElement.getContext('2d');
      }

      public start() {
        if (!this.ctx) return;
        this.canvas.width = this.canvas.parentElement?.clientWidth || 800;
        this.canvas.height = this.canvas.parentElement?.clientHeight || 600;
        this.particles = [];

        for (let i = 0; i < 120; i++) {
          this.particles.push({
            x: Math.random() * this.canvas.width,
            y: Math.random() * this.canvas.height - this.canvas.height,
            r: Math.random() * 5 + 3,
            d: Math.random() * this.canvas.height,
            color: this.colors[Math.floor(Math.random() * this.colors.length)],
            tilt: Math.random() * 10 - 5,
            tiltAngleIncremental: Math.random() * 0.07 + 0.02,
            tiltAngle: 0
          });
        }
        this.active = true;
        this.animate();
      }

      private animate() {
        if (!this.active || !this.ctx) return;
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        let remaining = false;

        this.particles.forEach(p => {
          p.tiltAngle += p.tiltAngleIncremental;
          p.y += (Math.cos(p.d) + 3 + p.r / 2) / 2;
          p.x += Math.sin(p.tiltAngle);
          p.tilt = Math.sin(p.tiltAngle - p.r / 2) * 5;

          if (p.y < this.canvas.height) {
            remaining = true;
          }

          this.ctx!.beginPath();
          this.ctx!.lineWidth = p.r;
          this.ctx!.strokeStyle = p.color;
          this.ctx!.moveTo(p.x + p.tilt + p.r / 2, p.y);
          this.ctx!.lineTo(p.x + p.tilt, p.y + p.tilt + p.r / 2);
          this.ctx!.stroke();
        });

        if (remaining) {
          requestAnimationFrame(() => this.animate());
        } else {
          this.active = false;
          this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        }
      }
    }

    const confetti = canvas ? new ConfettiEffect(canvas) : null;

    // Helpers to manage LocalStorage safely
    function checkLocalStorage() {
      try {
        return typeof window !== 'undefined' && 'localStorage' in window && window.localStorage !== null;
      } catch (e) {
        return false;
      }
    }
    const hasLocalStorage = checkLocalStorage();

    // Accordion Toggle Logic
    const headers = document.querySelectorAll('.fase-header');
    headers.forEach(h => {
      h.addEventListener('click', () => {
        const card = h.closest('.fase-card');
        if (card) card.classList.toggle('open');
      });
    });

    // Notes Toggle logic
    const noteBtns = document.querySelectorAll('.note-btn');
    noteBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const taskId = btn.getAttribute('data-task-id');
        const wrap = document.getElementById(`note-wrap-${taskId}`);
        const btnText = btn.querySelector('.note-btn-text');
        
        if (wrap && btnText) {
          wrap.classList.toggle('open');
          const isOpen = wrap.classList.contains('open');
          btnText.textContent = isOpen ? "Ocultar Nota" : "Editar Nota";
          
          if (isOpen) {
            const textarea = wrap.querySelector('textarea');
            if (textarea) textarea.focus();
          }
        }
      });
    });

    // Activity logging helper
    function addActivityLog(msg: string) {
      if (!hasLocalStorage || !tenderCode) return;
      const logKey = `vc-elemental-mp-tender-${tenderCode}-activity-log`;
      const savedLogs = localStorage.getItem(logKey);
      const logs = savedLogs ? JSON.parse(savedLogs) : [];
      
      const timestamp = new Date().toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' });
      logs.unshift({ timestamp, msg });
      
      // Limit to last 15 log messages
      const trimmed = logs.slice(0, 15);
      localStorage.setItem(logKey, JSON.stringify(trimmed));
      renderActivityLog();
    }

    function renderActivityLog() {
      if (!logList || !hasLocalStorage || !tenderCode) return;
      const logKey = `vc-elemental-mp-tender-${tenderCode}-activity-log`;
      const savedLogs = localStorage.getItem(logKey);
      const logs = savedLogs ? JSON.parse(savedLogs) : [];

      if (logs.length === 0) {
        logList.innerHTML = '<div class="log-entry">No hay actividad registrada aún.</div>';
        return;
      }

      logList.innerHTML = logs.map((log: any) => `
        <div class="log-entry">
          <span class="log-timestamp">[${log.timestamp}]</span>
          <span>${log.msg}</span>
        </div>
      `).join('');
    }

    // Dynamic color coding helper for selects
    function updateSelectColor(selectEl: HTMLSelectElement) {
      selectEl.classList.remove('status-pending', 'status-in-progress', 'status-completed');
      if (selectEl.value === 'pending') selectEl.classList.add('status-pending');
      else if (selectEl.value === 'in_progress') selectEl.classList.add('status-in-progress');
      else if (selectEl.value === 'completed') selectEl.classList.add('status-completed');
    }

    // Main logic to update percentages and badges
    function updateProgress() {
      const taskContainers = document.querySelectorAll('.task-item-container');
      const total = taskContainers.length;
      if (total === 0) return;

      let completedCount = 0;
      
      // Check status of each task
      taskContainers.forEach(container => {
        const taskId = container.getAttribute('data-task-id');
        const checkbox = container.querySelector('.pasoapaso-checkbox') as HTMLInputElement;
        const statusSelect = container.querySelector('.status-select') as HTMLSelectElement;
        
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = hasLocalStorage ? localStorage.getItem(stateKey) : null;
        const state = savedStateStr ? JSON.parse(savedStateStr) : { status: 'pending', assignee: '', notes: '' };

        // Sync statuses
        if (state.status === 'completed') {
          completedCount++;
          container.classList.add('completed-task');
          if (checkbox) checkbox.checked = true;
        } else {
          container.classList.remove('completed-task');
          if (checkbox) checkbox.checked = false;
        }

        if (statusSelect) {
          statusSelect.value = state.status;
          updateSelectColor(statusSelect);
        }
      });

      // Update total progress bar
      const percentage = Math.round((completedCount / total) * 100);
      if (progressBar) progressBar.style.width = `${percentage}%`;
      if (progressText) progressText.textContent = `${percentage}%`;

      // Update phase completion badges (e.g. 2/4)
      const phases = document.querySelectorAll('.fase-card');
      phases.forEach(phase => {
        const faseIdx = phase.getAttribute('data-fase');
        const phaseTasks = phase.querySelectorAll('.task-item-container');
        const phaseTotal = phaseTasks.length;
        let phaseCompleted = 0;
        
        phaseTasks.forEach(task => {
          if (task.classList.contains('completed-task')) {
            phaseCompleted++;
          }
        });

        const badge = document.getElementById(`fase-badge-${faseIdx}`);
        if (badge) {
          badge.textContent = `${phaseCompleted}/${phaseTotal}`;
          badge.classList.remove('complete');
          if (phaseCompleted === phaseTotal && phaseTotal > 0) {
            badge.classList.add('complete');
          }
        }
      });

      // Check for 100% celebration
      const celebratesKey = `vc-elemental-mp-tender-${tenderCode}-celebrated`;
      if (percentage === 100 && hasLocalStorage && localStorage.getItem(celebratesKey) !== 'true') {
        localStorage.setItem(celebratesKey, 'true');
        if (confetti) confetti.start();
        addActivityLog("🎉 ¡Postulación completa! Todos los hitos y requisitos han sido listados.");
      } else if (percentage < 100 && hasLocalStorage) {
        localStorage.removeItem(celebratesKey);
      }
    }

    // Load initial state for all tasks
    if (hasLocalStorage && tenderCode) {
      const taskContainers = document.querySelectorAll('.task-item-container');
      taskContainers.forEach(container => {
        const taskId = container.getAttribute('data-task-id');
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = localStorage.getItem(stateKey);
        
        if (savedStateStr) {
          const state = JSON.parse(savedStateStr);
          
          const checkbox = container.querySelector('.pasoapaso-checkbox') as HTMLInputElement;
          const assigneeSelect = container.querySelector('.assignee-select') as HTMLSelectElement;
          const statusSelect = container.querySelector('.status-select') as HTMLSelectElement;
          const textarea = container.querySelector('.note-textarea') as HTMLTextAreaElement;
          const noteBtn = container.querySelector('.note-btn');

          if (checkbox) checkbox.checked = (state.status === 'completed');
          if (assigneeSelect) assigneeSelect.value = state.assignee || '';
          if (statusSelect) {
            statusSelect.value = state.status || 'pending';
            updateSelectColor(statusSelect);
          }
          if (textarea) textarea.value = state.notes || '';
          
          if (state.notes && state.notes.trim() !== '') {
            if (noteBtn) {
              noteBtn.classList.add('has-notes');
              const btnText = noteBtn.querySelector('.note-btn-text');
              if (btnText) btnText.textContent = "Editar Nota";
            }
          }
        }
      });
      renderActivityLog();
    }

    // Listeners for Checkbox toggles
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.pasoapaso-checkbox');
    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        const taskId = cb.getAttribute('data-task-id') || '';
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = localStorage.getItem(stateKey);
        const state = savedStateStr ? JSON.parse(savedStateStr) : { status: 'pending', assignee: '', notes: '' };
        
        const container = cb.closest('.task-item-container');
        const taskTitle = container?.querySelector('.task-title')?.textContent || 'Tarea';

        const oldStatus = state.status;
        state.status = cb.checked ? 'completed' : 'pending';
        localStorage.setItem(stateKey, JSON.stringify(state));

        if (oldStatus !== state.status) {
          const statusEmoji = cb.checked ? '✅' : '⭕';
          addActivityLog(`${statusEmoji} José Valdés cambió el estado de "${taskTitle}" a ${cb.checked ? 'Completado' : 'Pendiente'}`);
        }
        updateProgress();
      });
    });

    // Listeners for Status selects
    const statusSelects = document.querySelectorAll<HTMLSelectElement>('.status-select');
    statusSelects.forEach(select => {
      select.addEventListener('change', () => {
        const taskId = select.getAttribute('data-task-id') || '';
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = localStorage.getItem(stateKey);
        const state = savedStateStr ? JSON.parse(savedStateStr) : { status: 'pending', assignee: '', notes: '' };
        
        const container = select.closest('.task-item-container');
        const taskTitle = container?.querySelector('.task-title')?.textContent || 'Tarea';

        const oldStatus = state.status;
        state.status = select.value;
        localStorage.setItem(stateKey, JSON.stringify(state));

        if (oldStatus !== state.status) {
          const statusText = select.value === 'completed' ? 'Completado ✅' : select.value === 'in_progress' ? 'En Proceso ⏳' : 'Pendiente ⭕';
          addActivityLog(`🔄 José Valdés actualizó el estado de "${taskTitle}" a: ${statusText}`);
        }
        updateProgress();
      });
    });

    // Listeners for Assignee changes
    const assigneeSelects = document.querySelectorAll<HTMLSelectElement>('.assignee-select');
    assigneeSelects.forEach(select => {
      select.addEventListener('change', () => {
        const taskId = select.getAttribute('data-task-id') || '';
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = localStorage.getItem(stateKey);
        const state = savedStateStr ? JSON.parse(savedStateStr) : { status: 'pending', assignee: '', notes: '' };
        
        const container = select.closest('.task-item-container');
        const taskTitle = container?.querySelector('.task-title')?.textContent || 'Tarea';

        const oldAssignee = state.assignee;
        state.assignee = select.value;
        localStorage.setItem(stateKey, JSON.stringify(state));

        if (oldAssignee !== state.assignee) {
          const assignedText = select.value ? `asignada a ${select.value} 👤` : 'desasignada 👤';
          addActivityLog(`👤 Tarea "${taskTitle}" fue ${assignedText}`);
        }
      });
    });

    // Listeners for Notes typing
    const noteTextareas = document.querySelectorAll<HTMLTextAreaElement>('.note-textarea');
    noteTextareas.forEach(textarea => {
      textarea.addEventListener('input', () => {
        const taskId = textarea.getAttribute('data-task-id') || '';
        const stateKey = `vc-elemental-mp-tender-${tenderCode}-task-${taskId}`;
        const savedStateStr = localStorage.getItem(stateKey);
        const state = savedStateStr ? JSON.parse(savedStateStr) : { status: 'pending', assignee: '', notes: '' };
        
        state.notes = textarea.value;
        localStorage.setItem(stateKey, JSON.stringify(state));

        const container = textarea.closest('.task-item-container');
        const noteBtn = container?.querySelector('.note-btn');

        if (noteBtn) {
          if (textarea.value.trim() !== '') {
            noteBtn.classList.add('has-notes');
          } else {
            noteBtn.classList.remove('has-notes');
            const btnText = noteBtn.querySelector('.note-btn-text');
            if (btnText) btnText.textContent = "Agregar Nota";
          }
        }
      });

      textarea.addEventListener('blur', () => {
        const container = textarea.closest('.task-item-container');
        const taskTitle = container?.querySelector('.task-title')?.textContent || 'Tarea';
        
        if (textarea.value.trim() !== '') {
          addActivityLog(`📝 José Valdés añadió/editó una nota en "${taskTitle}"`);
        }
      });
    });

    // Export Checklist functionality
    if (exportBtn) {
      exportBtn.addEventListener('click', () => {
        const code = tenderCode || 'Licitacion';
        let output = `# CHECKLIST DE POSTULACIÓN - LICITACIÓN ${code}\n`;
        output += `Generado el: ${new Date().toLocaleDateString('es-CL')}\n\n`;

        const phases = document.querySelectorAll('.fase-card');
        phases.forEach(phase => {
          const header = phase.querySelector('.fase-title span:first-child')?.textContent || 'Fase';
          const badge = phase.querySelector('.fase-badge')?.textContent || '';
          output += `## ${header} (${badge})\n`;

          const tasks = phase.querySelectorAll('.task-item-container');
          tasks.forEach(task => {
            const title = task.querySelector('.task-title')?.textContent || '';
            const desc = task.querySelector('.task-detail')?.textContent || '';
            
            const assigneeSelect = task.querySelector('.assignee-select') as HTMLSelectElement;
            const statusSelect = task.querySelector('.status-select') as HTMLSelectElement;
            const textarea = task.querySelector('.note-textarea') as HTMLTextAreaElement;

            const isExcluyente = task.classList.contains('excluyente') ? ' [EXCLUYENTE]' : '';
            const assignee = assigneeSelect && assigneeSelect.value ? ` (Encargado: ${assigneeSelect.value})` : ' (Sin asignar)';
            const status = statusSelect ? statusSelect.value === 'completed' ? ' [COMPLETADA]' : statusSelect.value === 'in_progress' ? ' [EN PROCESO]' : ' [PENDIENTE]' : '';
            
            output += `- [${statusSelect && statusSelect.value === 'completed' ? 'x' : ' '}] ${title}${isExcluyente}${assignee}${status}\n`;
            if (desc) output += `  *Detalle: ${desc}*\n`;
            if (textarea && textarea.value.trim()) output += `  *Nota: "${textarea.value.trim()}"*\n`;
          });
          output += `\n`;
        });

        navigator.clipboard.writeText(output).then(() => {
          alert('¡Checklist copiado al portapapeles en formato Markdown! Puedes pegarlo en un correo, Slack o WhatsApp.');
          addActivityLog("📋 Copiado reporte de checklist al portapapeles.");
        }).catch(err => {
          console.error('Error al copiar checklist:', err);
          alert('No se pudo copiar el checklist de manera automática. Revisa la consola.');
        });
      });
    }

    // Initial calculation
    updateProgress();
  </script>
</DashboardLayout>
