];

// Dynamic generator for personalized step-by-step guide
function generatePasoAPaso(tenderObj: any, basesObj: any, _rawData: any) {
  const fases = [
    {
      title: "Fase 1: Admisibilidad y Aclaraciones Iniciales 🔍",
      desc: "Hitos preliminares y requisitos de entrada que no admiten errores.",
      items: [] as Array<{ label: string; detail: string; excluyente?: boolean; estrategico?: boolean }>
    },
    {
      title: "Fase 2: Preparación y Firmas de Anexos 📂",
      desc: "Recopilación de declaraciones juradas, poderes legales y acreditación previsional.",
      items: [] as Array<{ label: string; detail: string; excluyente?: boolean; estrategico?: boolean }>
    },
    {
      title: "Fase 3: Desarrollo Técnico y Oferta de Equipo ⚙️",
      desc: "Plan metodológico de trabajo y conformación de los perfiles expertos requeridos.",
      items: [] as Array<{ label: string; detail: string; excluyente?: boolean; estrategico?: boolean }>
    },
    {
      title: "Fase 4: Oferta Económica y Control de Calidad Final 🚀",
      desc: "Revisión final de anexos económicos y envío antes de la hora de cierre.",
      items: [] as Array<{ label: string; detail: string; excluyente?: boolean; estrategico?: boolean }>
    }
  ];

  // --- FASE 1: Admisibilidad ---
  // 1. Visita a terreno / Reunión obligatoria
  let meetingFound = false;
  const sectionsToCheck = [
    basesObj?.etapasPlazos,
    basesObj?.requisitosContratar,
    basesObj?.requerimientosTecnicos
  ];
  for (const sect of sectionsToCheck) {
    if (!sect) continue;
    const lines = sect.split('\n');
    for (const line of lines) {
      const lLower = line.toLowerCase();
      if (lLower.includes('reunión') || lLower.includes('visita') || lLower.includes('terreno') || lLower.includes('presencial') || lLower.includes('charla')) {
        fases[0].items.push({
          label: "Asistir obligatoriamente a reunión / visita a terreno.",
          detail: line.replace(/^[•*\s\-]+/, ''),
          excluyente: true
        });
        meetingFound = true;
        break;
      }
    }
    if (meetingFound) break;
  }
  if (!meetingFound && requisitosExcluyentes) {
    for (const req of requisitosExcluyentes) {
      const rLower = req.toLowerCase();
      if (rLower.includes('reunión') || rLower.includes('visita') || rLower.includes('terreno')) {
        fases[0].items.push({
          label: "Asistir a la reunión informativa o visita presencial obligatoria.",
          detail: req,
          excluyente: true
        });
        meetingFound = true;
        break;
      }
    }
  }

  // 2. Subcontratación
  let subconFound = false;
  const subconSections = [basesObj?.montosDuracion, basesObj?.requerimientosTecnicos];
  for (const sect of subconSections) {
    if (!sect) continue;
    const lines = sect.split('\n');
    for (const line of lines) {
      if (line.toLowerCase().includes('subcontrat') && (line.toLowerCase().includes('prohib') || line.toLowerCase().includes('no permit') || line.toLowerCase().includes('no se autoriza'))) {
        fases[0].items.push({
          label: "Respetar prohibición de subcontratación.",
          detail: line.replace(/^[•*\s\-]+/, ''),
          excluyente: true
        });
        subconFound = true;
        break;
      }
    }
    if (subconFound) break;
  }
  if (!subconFound && requisitosExcluyentes) {
    for (const req of requisitosExcluyentes) {
      if (req.toLowerCase().includes('subcontrat')) {
        fases[0].items.push({
          label: "Prohibición de subcontratar: Revisar condiciones operativas.",
          detail: req,
          excluyente: true
        });
        subconFound = true;
        break;
      }
    }
  }

  // 3. Foro de Consultas
  let forumDate = "Revisar foro de preguntas en Mercado Público.";
  if (basesObj?.etapasPlazos) {
    const questionsLine = basesObj.etapasPlazos.split('\n').find((l: string) => l.toLowerCase().includes('pregunta') || l.toLowerCase().includes('foro'));
    if (questionsLine) {
      forumDate = questionsLine.replace(/^[•*\s\-]+/, '');
    }
  }
  fases[0].items.push({
    label: "Revisar y enviar consultas al Foro de Preguntas.",
    detail: forumDate,
    estrategico: true
  });


  // --- FASE 2: Preparación de Anexos ---
  // 1. ChileProveedores y F30-1
  fases[1].items.push({
    label: "Acreditar habilidad en Registro ChileProveedores y certificado previsional.",
    detail: "El oferente debe estar en estado 'HÁBIL'. Se exige no registrar deudas previsionales ni de salud con los trabajadores (Certificado F30-1).",
    excluyente: true
  });

  // 2. Anexos administrativos
  let docCount = 0;
  if (basesObj?.antecedentes) {
    const lines = basesObj.antecedentes.split('\n');
    for (const line of lines) {
      const cleanLine = line.replace(/^[•*\s\-]+/, '').trim();
      if (cleanLine.toLowerCase().includes('anexo') || cleanLine.toLowerCase().includes('declaración jurada') || cleanLine.toLowerCase().includes('formulario')) {
        const isEconomic = cleanLine.toLowerCase().includes('económ') || cleanLine.toLowerCase().includes('precio') || cleanLine.toLowerCase().includes('anexo 5');
        const isTechnical = cleanLine.toLowerCase().includes('técnic') || cleanLine.toLowerCase().includes('metodolog') || cleanLine.toLowerCase().includes('experiencia') || cleanLine.toLowerCase().includes('anexo 6') || cleanLine.toLowerCase().includes('anexo 7');
        if (!isEconomic && !isTechnical) {
          fases[1].items.push({
            label: `Preparar y firmar: ${cleanLine}`,
            detail: "Asegurar que esté completo, firmado digitalmente por el representante legal.",
            excluyente: cleanLine.toLowerCase().includes('anexo 1') || cleanLine.toLowerCase().includes('anexo 2') || cleanLine.toLowerCase().includes('obligatorio')
          });
          docCount++;
        }
      }
    }
  }
  if (docCount === 0 && requisitos) {
    for (const req of requisitos) {
      if (req.toLowerCase().includes('anexo') || req.toLowerCase().includes('declaración')) {
        fases[1].items.push({
          label: `Preparar: ${req}`,
          detail: "Completar la información legal y adjuntar firma.",
          excluyente: true
        });
        docCount++;
      }
    }
  }
  if (docCount === 0) {
    fases[1].items.push({
      label: "Preparar Anexo N° 1 (Identificación del Oferente y Aceptación de Bases).",
      detail: "Formulario administrativo básico indispensable.",
      excluyente: true
    });
    fases[1].items.push({
      label: "Preparar Anexo N° 2 (Declaración Jurada de No Inhabilidades).",
      detail: "Declaración firmada de no tener prohibiciones para contratar con el Estado.",
      excluyente: true
    });
  }

  // 3. Garantía de Seriedad
  let warrantyText = "No se menciona boleta de seriedad o se indica exención.";
  let seriedadExigida = false;
  if (basesObj?.garantias) {
    const lines = basesObj.garantias.split('\n');
    for (const line of lines) {
      if (line.toLowerCase().includes('seriedad')) {
        warrantyText = line.replace(/^[•*\s\-]+/, '');
        seriedadExigida = !line.toLowerCase().includes('no se exige') && !line.toLowerCase().includes('no se requiere');
        break;
      }
    }
  }
  fases[1].items.push({
    label: seriedadExigida ? "Gestionar Boleta de Garantía de Seriedad de la Oferta." : "Verificar exención de Garantía de Seriedad.",
    detail: warrantyText,
    excluyente: seriedadExigida
  });


  // --- FASE 3: Desarrollo Técnico ---
  // 1. Propuesta Técnica
  let techWeight = "";
  if (basesObj?.criteriosEvaluacion) {
    const techLine = basesObj.criteriosEvaluacion.split('\n').find((l: string) => l.toLowerCase().includes('técnic'));
    if (techLine) {
      techWeight = ` (Ponderación: ${techLine.replace(/^[•*\s\-]+/, '')})`;
    }
  }
  fases[2].items.push({
    label: `Desarrollar la Propuesta Técnica Metodológica${techWeight}.`,
    detail: `Redactar una metodología robusta alineada con el objetivo: "${tenderObj.title}".`,
    excluyente: true
  });

  // 2. Personal Técnico
  let profilesCount = 0;
  if (basesObj?.antecedentes) {
    const lines = basesObj.antecedentes.split('\n');
    for (const line of lines) {
      const cleanLine = line.replace(/^[•*\s\-]+/, '').trim();
      if ((cleanLine.toLowerCase().includes('experiencia') || cleanLine.toLowerCase().includes('currículum') || cleanLine.toLowerCase().includes('personal') || cleanLine.toLowerCase().includes('anexo 6') || cleanLine.toLowerCase().includes('anexo 7')) && !cleanLine.toLowerCase().includes('oferente')) {
        fases[2].items.push({
          label: `Acreditar perfil: ${cleanLine}`,
          detail: "Completar la ficha correspondiente y adjuntar currículums y certificados de título.",
          excluyente: true
        });
        profilesCount++;
      }
    }
  }
  if (profilesCount === 0 && requisitosExcluyentes) {
    for (const req of requisitosExcluyentes) {
      if (req.toLowerCase().includes('diseñador') || req.toLowerCase().includes('desarrollador') || req.toLowerCase().includes('experiencia del personal')) {
        fases[2].items.push({
          label: `Acreditar equipo mínimo: ${req}`,
          detail: "Demostrar experiencia del equipo técnico propuesto.",
          excluyente: true
        });
        profilesCount++;
      }
    }
  }


  // --- FASE 4: Oferta Económica y Cierre ---
  // 1. Oferta Económica
  let ecoWeight = "";
  if (basesObj?.criteriosEvaluacion) {
    const ecoLine = basesObj.criteriosEvaluacion.split('\n').find((l: string) => l.toLowerCase().includes('económ') || l.toLowerCase().includes('precio'));
    if (ecoLine) {
      ecoWeight = ` (Ponderación: ${ecoLine.replace(/^[•*\s\-]+/, '')})`;
    }
  }
  
  let economicLabel = "Completar Formulario de Oferta Económica.";
  if (tenderObj.budget > 0) {
    economicLabel = `Completar Formulario de Oferta Económica sin superar presupuesto de ${formatBudget(tenderObj.budget, tenderObj.currency)}${ecoWeight}.`;
  }
  fases[3].items.push({
    label: economicLabel,
    detail: "Ingresar precio neto unitario y total en el portal y adjuntar el anexo respectivo firmado.",
    excluyente: true
  });

  // 2. Control de Calidad / Foro Inverso
  let reverseForum = "Revisar acuciosamente que no falte ningún documento antes del envío.";
  if (basesObj?.requerimientosTecnicos) {
    const lines = basesObj.requerimientosTecnicos.split('\n');
    for (const line of lines) {
      if (line.toLowerCase().includes('foro inverso') || line.toLowerCase().includes('aclaraciones') || line.toLowerCase().includes('subsanar')) {
        reverseForum = `${line.replace(/^[•*\s\-]+/, '')}. ¡Subsanar descuenta puntaje de formalidad!`;
        break;
      }
    }
  }
  fases[3].items.push({
    label: "Control de Calidad: Evitar Foro Inverso y errores formales.",
    detail: reverseForum,
    estrategico: true
  });

  // 3. Envío y hora de cierre
  let tiebreakerText = "Enviar con anticipación. En caso de empate, el orden/hora de ingreso define al ganador.";
  if (basesObj?.requerimientosTecnicos) {
    const lines = basesObj.requerimientosTecnicos.split('\n');
    const tiebreakerLine = lines.find((l: string) => l.toLowerCase().includes('desempate') || l.toLowerCase().includes('hora de ingreso') || l.toLowerCase().includes('orden de ingreso'));
    if (tiebreakerLine) {
      tiebreakerText = `Desempate: ${tiebreakerLine.replace(/^[•*\s\-]+/, '')}.`;
    }
  }
  fases[3].items.push({
    label: `Enviar propuesta final antes del cierre: ${new Date(tenderObj.closeDate).toLocaleString('es-CL')}.`,
    detail: tiebreakerText,
    excluyente: true
  });

  return fases;
}

const activePasoAPaso = generatePasoAPaso(tender, dbTextoBases, rawDataObj);
