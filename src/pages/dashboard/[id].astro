      text-decoration: line-through;
      color: var(--muted);
    }
    .task-detail {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }

    /* Task controls row */
    .task-controls-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid rgba(255, 255, 255, 0.03);
    }
    .control-group {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .control-label {
      font-size: 11px;
      color: var(--muted);
      font-weight: 600;
    }
    .task-select {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 12px;
      font-weight: 550;
      padding: 4px 8px;
      border-radius: 6px;
      cursor: pointer;
      outline: none;
      transition: all 0.2s ease;
    }
    .task-select:hover {
      border-color: var(--muted);
    }
    
    /* Dynamic color code for task select status */
    .task-select.status-pending { color: var(--muted2); }
    .task-select.status-in-progress { color: #f59e0b; border-color: rgba(245, 158, 11, 0.3); background: rgba(245, 158, 11, 0.05); }
    .task-select.status-completed { color: #10b981; border-color: rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.05); }

    .note-btn {
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 12px;
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 4px 8px;
      border-radius: 6px;
      font-weight: 500;
      transition: all 0.2s ease;
    }
    .note-btn:hover {
      color: var(--text);
      background: rgba(255, 255, 255, 0.02);
    }
    .note-btn.has-notes {
      color: var(--accent);
      background: rgba(59, 130, 246, 0.05);
    }

    .task-note-input-wrapper {
      display: none;
      margin-top: 8px;
      width: 100%;
    }
    .task-note-input-wrapper.open {
      display: block;
    }
    .task-textarea {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 12px;
      padding: 8px;
      border-radius: 8px;
      resize: vertical;
      min-height: 50px;
      outline: none;
      font-family: inherit;
    }
    .task-textarea:focus {
      border-color: var(--accent);
    }

    /* Confetti canvas */
    #confetti-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 10;
    }

    /* Activity log panel */
    .activity-log-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      margin-top: 24px;
      text-align: left;
    }
    .activity-log-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .activity-log-container {
      max-height: 180px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-right: 8px;
    }
    .log-entry {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.4;
      padding-bottom: 6px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.02);
