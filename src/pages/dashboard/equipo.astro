---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Datos de miembros mock
const mockTeam = [
  { name: 'José Valdés', email: 'jose@vcelemental.cl', role: 'Owner', status: 'Activo', initial: 'JV' },
  { name: 'Teddy Summarize', email: 'teddy@vcelemental.cl', role: 'Admin', status: 'Activo', initial: 'TS' },
  { name: 'Ignacio Carrasco', email: 'ignacio@vcelemental.cl', role: 'Analyst', status: 'Activo', initial: 'IC' },
  { name: 'Camila Rojas', email: 'camila@vcelemental.cl', role: 'Viewer', status: 'Invitación Pendiente', initial: 'CR' },
];
---
<DashboardLayout title="Equipo" activeTab="equipo">
  <style>
    .content { padding: 32px; display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 16px; padding: 24px;
    }
    .card-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
    .card-desc { font-size: 13px; color: var(--muted); margin-bottom: 24px; }

    /* Team List */
    .team-list { display: flex; flex-direction: column; gap: 14px; }
    .team-member {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px; background: var(--surface2); border: 1px solid var(--border);
      border-radius: 12px;
    }
    .member-info { display: flex; align-items: center; gap: 12px; }
    .member-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: bold; color: white;
    }
    .member-name { font-size: 14px; font-weight: 600; }
    .member-email { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .member-meta { display: flex; align-items: center; gap: 16px; }
    
    .role-badge {
      font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 50px;
    }
    .role-owner { background: rgba(139,92,246,0.1); color: var(--accent2); border: 1px solid rgba(139,92,246,0.2); }
    .role-admin { background: rgba(59,130,246,0.1); color: var(--accent); border: 1px solid rgba(59,130,246,0.2); }
    .role-analyst { background: rgba(34,197,94,0.1); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
    .role-viewer { background: rgba(100,116,139,0.1); color: var(--muted2); border: 1px solid rgba(100,116,139,0.2); }
    
    .status-badge {
      font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px;
    }
    .status-active { background: rgba(34,197,94,0.08); color: var(--green); }
    .status-pending { background: rgba(234,179,8,0.08); color: var(--yellow); }

    /* Form invites */
    .form-group { margin-bottom: 16px; }
    label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
    .input-text, select {
      background: var(--surface2); border: 1px solid var(--border); border-radius: 8px;
      color: var(--text); padding: 10px 12px; font-size: 13px; width: 100%; outline: none;
      font-family: inherit;
    }
    .input-text:focus, select:focus { border-color: var(--accent); }
    
    .btn-invite {
      width: 100%; padding: 12px; font-size: 13px; font-weight: 700; border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), var(--accent2)); color: white;
      border: none; cursor: pointer; margin-top: 8px;
    }

    /* Premium Toast */
    .toast {
      position: fixed; top: 24px; right: 24px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: #10b981;
      padding: 16px 24px; border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      backdrop-filter: blur(12px);
      z-index: 1000;
      display: flex; align-items: center; gap: 10px;
      transform: translateY(-20px); opacity: 0;
      pointer-events: none;
      transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      font-size: 14px; font-weight: 600;
    }
    .toast.show {
      transform: translateY(0); opacity: 1;
    }
  </style>

  <div class="topbar">
    <div class="topbar-left">
      <h1>👥 Miembros del Equipo</h1>
      <p>Administra los accesos y roles de tu organización</p>
    </div>
  </div>

  <div class="content">
    <!-- Success Toast -->
    <div id="success-toast" class="toast">
      <span>✉️</span>
      <span id="toast-text">¡Invitación enviada con éxito!</span>
    </div>

    <!-- List -->
    <div class="card">
      <div class="card-title">Equipo VC Elemental</div>
      <div class="card-desc">Miembros con acceso a este panel y licitaciones</div>
      
      <div class="team-list">
        {mockTeam.map(member => {
          const roleClass = member.role === 'Owner' ? 'role-owner' : member.role === 'Admin' ? 'role-admin' : member.role === 'Analyst' ? 'role-analyst' : 'role-viewer';
          const statusClass = member.status === 'Activo' ? 'status-active' : 'status-pending';
          return (
            <div class="team-member">
              <div class="member-info">
                <div class="member-avatar">{member.initial}</div>
                <div>
                  <div class="member-name">{member.name}</div>
                  <div class="member-email">{member.email}</div>
                </div>
              </div>
              <div class="member-meta">
                <span class={`status-badge ${statusClass}`}>{member.status}</span>
                <span class={`role-badge ${roleClass}`}>{member.role}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Invite -->
    <div class="card" style="height: fit-content;">
      <div class="card-title">Invitar Nuevo Miembro</div>
      <div class="card-desc">El usuario recibirá un correo para unirse</div>

      <div class="form-group">
        <label for="invite-name">Nombre Completo</label>
        <input type="text" id="invite-name" class="input-text" placeholder="Ej: Juan Pérez" />
      </div>

      <div class="form-group">
        <label for="invite-email">Correo Electrónico</label>
        <input type="email" id="invite-email" class="input-text" placeholder="juan@empresa.com" />
      </div>

      <div class="form-group">
        <label for="invite-role">Rol asignado</label>
        <select id="invite-role">
          <option value="viewer">Viewer (Solo lectura)</option>
          <option value="analyst">Analyst (Ve y config. alertas)</option>
          <option value="admin">Admin (Gestión completa de equipo)</option>
        </select>
      </div>

      <button class="btn-invite" id="btn-send-invite">Enviar Invitación</button>
    </div>
  </div>

  <script>
    const inviteBtn = document.getElementById('btn-send-invite');
    const toast = document.getElementById('success-toast');
    const toastText = document.getElementById('toast-text');

    if (inviteBtn) {
      inviteBtn.addEventListener('click', () => {
        const nameInput = document.getElementById('invite-name');
        const emailInput = document.getElementById('invite-email');
        const email = emailInput ? emailInput.value.trim() : '';

        if (!email) {
          // Toast rojo de error
          if (toast && toastText) {
            toast.style.background = 'rgba(239, 68, 68, 0.1)';
            toast.style.borderColor = 'rgba(239, 68, 68, 0.2)';
            toast.style.color = '#ef4444';
            toast.innerHTML = '<span>❌</span><span>Por favor introduce un correo válido</span>';
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
          }
          return;
        }

        // Mostrar toast verde de éxito
        if (toast && toastText) {
          toast.style.background = 'rgba(16, 185, 129, 0.1)';
          toast.style.borderColor = 'rgba(16, 185, 129, 0.2)';
          toast.style.color = '#10b981';
          toast.innerHTML = `<span>✉️</span><span>¡Invitación enviada con éxito a ${email}!</span>`;
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 3000);
        }

        // Limpiar inputs
        if (nameInput) nameInput.value = '';
        if (emailInput) emailInput.value = '';
      });
    }
  </script>
</DashboardLayout>
